# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client (Google Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js — generate with: npx auth secret
AUTH_SECRET=
# Required in production if it can't be inferred from request headers, e.g.:
# AUTH_URL=https://your-app.vercel.app

# Shared secret the rollover cron route checks for (any random string).
# Vercel Cron sends it automatically as "Authorization: Bearer $CRON_SECRET"
# once this is set as a project env var — see vercel.json.
CRON_SECRET=

# Anthropic API key (console.anthropic.com -> API Keys) — powers the "paste
# a to-do list and let Archie sort it into categories" feature.
ANTHROPIC_API_KEY=
